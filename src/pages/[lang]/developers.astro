---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
import { getPublicCopy } from '@/lib/publicCopy';
const lang = normalizeLang(Astro.params.lang);
const copy = getPublicCopy(lang);
---
<BaseLayout title={copy.developers.title} lang={lang} description={copy.developers.description}>
  <PageHeader eyebrow={copy.portalEyebrow} title={copy.developers.title} description={copy.developers.description} />
  <div class="terminal-panel prose-stellar p-6">
    <p>{copy.developers.body}</p>
  </div>
</BaseLayout>
