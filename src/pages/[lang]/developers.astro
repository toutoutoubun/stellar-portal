---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
const lang = normalizeLang(Astro.params.lang);
---
<BaseLayout title="Developers" lang={lang}>
  <PageHeader eyebrow="stellar portal" title="Developers" description="Developer registration grants submission rights for reviewed community addons." />
  <div class="terminal-panel prose-stellar p-6">
    <p>Developer registration grants submission rights for reviewed community addons.</p>
  </div>
</BaseLayout>
