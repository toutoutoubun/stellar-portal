---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import AccountForm from '@/components/AccountForm';
import { getViewer } from '@/lib/access';
import { normalizeLang } from '@/lib/i18n';

const lang = normalizeLang(Astro.params.lang);
const viewer = await getViewer(Astro);

if (!viewer.user) {
  return Astro.redirect(`/${lang}/login`);
}

const profile = viewer.profile ?? {
  display_name: null,
  avatar_url: null,
  email: viewer.user.email ?? null,
  role: 'free_user',
  subscription_status: 'none'
};
---
<DashboardLayout title="Account">
  <PageHeader
    eyebrow="identity file"
    title="Account"
    description="Manage the account record attached to this Stellar Portal login."
  />
  <div class="max-w-2xl">
    <AccountForm client:load profile={profile} />
  </div>
</DashboardLayout>
