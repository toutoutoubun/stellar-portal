---
<BaseLayout title={copy.homeTitle} lang={lang} description={t(lang, 'tagline')}>
  <ConsoleHero lang={lang} />

  <section id="projects" class="mt-20">
    <div class="mb-6 flex flex-wrap items-end justify-between gap-4 px-0 sm:px-4">
      <h2 class="font-mono text-4xl font-bold tracking-[.08em] text-stellar-text">{copy.projectsTitle}</h2>
      <p class="font-mono text-xs font-bold uppercase tracking-[.18em] text-stellar-muted">{copy.projectsCount}</p>
    </div>
    <div class="grid overflow-hidden rounded-[1.4rem] border border-stellar-border lg:grid-cols-2">
      <a class="project-card project-card-blue block" href={`/${lang}/wiki`}>
        <p class="project-meta">{copy.projectOneMeta}</p>
        <p class="project-number">01</p>
        <h3 class="project-title">{copy.projectOneTitle}</h3>
        <p class="project-pill">{copy.projectOnePill}</p>
        <p class="project-body">{copy.projectOneBody}</p>
        <span class="btn btn-primary project-action">{copy.projectOneAction}</span>
      </a>
      <a class="project-card project-card-gold block" href={`/${lang}/addons`}>
        <p class="project-meta">{copy.projectTwoMeta}</p>
        <p class="project-number">02</p>
        <h3 class="project-title">{copy.projectTwoTitle}</h3>
        <p class="project-pill">{copy.projectTwoPill}</p>
        <p class="project-body">{copy.projectTwoBody}</p>
        <span class="btn project-action">{copy.projectTwoAction}</span>
      </a>
    </div>
  </section>

  <section class="refusal-band relative -mx-4 mt-20 overflow-hidden px-4 py-20 text-[#fffaf1] sm:-mx-6 sm:px-8 lg:-mx-8 lg:px-20">
    <p class="inline-flex rounded-full bg-[var(--gold)] px-6 py-3 font-mono text-xs font-bold uppercase tracking-[.22em] text-stellar-text"><span class="mr-3 text-stellar-accent">●</span>{copy.refuseEyebrow}</p>
    <h2 class="mt-10 max-w-5xl text-6xl font-black leading-tight sm:text-8xl">{copy.refuseTitle}</h2>
    <div class="mt-16 border-t border-dashed border-[#fffaf1]/45 pt-16">
      <div class="grid gap-12 lg:grid-cols-3">
        {copy.refuseItems.map(([number, title, body]) => (
          <article>
            <p class="grid h-20 w-20 place-items-center rounded-full bg-[var(--gold)] font-mono text-2xl font-black text-[#bf5b3a]">{number}</p>
            <h3 class="mt-8 text-4xl font-black">{title}</h3>
            <p class="mt-6 max-w-sm text-lg font-bold leading-9 text-[#fffaf1]/86">{body}</p>
          </article>
        ))}
      </div>
    </div>
    <span class="absolute right-24 top-16 h-28 w-28 rounded-full border-[6px] border-[var(--gold)]"></span>
    <span class="absolute bottom-20 right-16 h-12 w-12 rounded-full bg-[var(--pale-blue)]"></span>
    <span class="absolute bottom-20 left-28 text-5xl text-[var(--pale-blue)]">✦</span>
  </section>

  <section class="mx-auto mt-20 max-w-7xl">
    <PageHeader eyebrow={copy.wikiEyebrow} title={t(lang, 'officialWiki')} description={copy.wikiSectionDescription} />
    <div class="grid gap-4 lg:grid-cols-3">
      {featuredWiki.map((page) => (
        <a class="terminal-panel block p-5 hover:border-stellar-accent" href={`/${lang}/wiki/${page.slug}`}>
          <p class="font-mono text-xs uppercase tracking-[.14em] text-stellar-accent">{page.category}</p>
          <h2 class="mt-3 font-mono text-xl leading-8">{page.title}</h2>
          <p class="mt-3 line-clamp-3 leading-7 text-stellar-muted">{page.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto mt-20 max-w-7xl">
    <PageHeader eyebrow={copy.reviewedEyebrow} title={copy.addonsTitle} description={copy.addonsDescription} />
    <div class="grid gap-4">
      {(addons ?? []).length ? addons?.map((addon) => <AddonCard addon={addon} />) : <p class="text-stellar-muted">{t(lang, 'noAddons')}</p>}
    </div>
  </section>
</BaseLayout>
