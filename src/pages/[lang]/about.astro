---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
const lang = normalizeLang(Astro.params.lang);
---
<BaseLayout title="About Stellar" lang={lang}>
  <PageHeader eyebrow="stellar portal" title="About Stellar" description="A local-first research desktop for papers, notes, highlights, graphs, and analysis." />
  <div class="terminal-panel prose-stellar p-6">
    <p>A local-first research desktop for papers, notes, highlights, graphs, and analysis.</p>
  </div>
</BaseLayout>
