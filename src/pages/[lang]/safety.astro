---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
import { getPublicCopy } from '@/lib/publicCopy';
const lang = normalizeLang(Astro.params.lang);
const copy = getPublicCopy(lang);
---
<BaseLayout title={copy.safety.title} lang={lang} description={copy.safety.description}>
  <PageHeader eyebrow={copy.portalEyebrow} title={copy.safety.title} description={copy.safety.description} />
  <div class="terminal-panel prose-stellar p-6">
    {copy.safety.body.map((paragraph) => <p>{paragraph}</p>)}
  </div>
</BaseLayout>
