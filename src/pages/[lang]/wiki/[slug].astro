---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import ShareButtons from '@/components/ShareButtons';
import { normalizeLang } from '@/lib/i18n';
import { getEnv } from '@/lib/env';
import { getRelatedWikiPages, getWikiPage } from '@/lib/wiki';
const lang = normalizeLang(Astro.params.lang);
const slug = Astro.params.slug!;
const page = getWikiPage(lang, slug);
if (!page) return new Response('Not found', { status: 404 });
const env = getEnv();
const url = new URL(Astro.url.pathname, env.PUBLIC_SITE_URL).toString();
const relatedPages = getRelatedWikiPages(lang, page.related);
---
<BaseLayout title={page.title} description={page.summary} lang={lang}>
  <PageHeader eyebrow={page.category} title={page.title} description={page.summary} />

  <div class="mb-6 flex flex-wrap items-center gap-3 font-mono text-xs uppercase tracking-[.14em] text-stellar-muted">
    <a class="border border-stellar-border px-3 py-2 hover:border-stellar-accent" href={`/${lang}/wiki`}>Wiki index</a>
    <span class="border border-stellar-border px-3 py-2">/{page.slug}</span>
    <time class="border border-stellar-border px-3 py-2" datetime={page.updatedAt}>Updated {page.updatedAt}</time>
  </div>

  <article class="grid gap-5">
    {page.sections.map((section) => (
      <section class="prose-stellar terminal-panel max-w-none p-6">
        <h2 class="mb-4 text-xl text-stellar-text">{section.heading}</h2>
        {section.body.map((paragraph) => <p>{paragraph}</p>)}
        {section.bullets && (
          <ul class="mt-5 grid gap-2 pl-0">
            {section.bullets.map((item) => (
              <li class="list-none border-l border-stellar-accent bg-stellar-panel2 px-4 py-3 leading-7 text-stellar-muted">
                {item}
              </li>
            ))}
          </ul>
        )}
      </section>
    ))}
  </article>

  {relatedPages.length > 0 && (
    <section class="mt-8">
      <h2 class="mb-4 font-mono text-sm uppercase tracking-[.18em] text-stellar-accent">Related docs</h2>
      <div class="grid gap-4 md:grid-cols-3">
        {relatedPages.map((related) => (
          <a class="terminal-panel block p-5 hover:border-stellar-accent" href={`/${lang}/wiki/${related.slug}`}>
            <p class="font-mono text-lg text-stellar-text">{related.title}</p>
            <p class="mt-3 line-clamp-3 leading-7 text-stellar-muted">{related.summary}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="mt-6"><ShareButtons client:load title={page.title} url={url} /></div>
</BaseLayout>
