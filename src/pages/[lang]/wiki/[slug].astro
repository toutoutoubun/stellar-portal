---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import ShareButtons from '@/components/ShareButtons';
import { normalizeLang } from '@/lib/i18n';
import { createSupabaseServer } from '@/lib/supabaseServer';
import { getEnv } from '@/lib/env';
const lang = normalizeLang(Astro.params.lang);
const slug = Astro.params.slug!;
const supabase = createSupabaseServer(Astro);
const { data: page } = await supabase.from('wiki_pages').select('*').eq('locale', lang).eq('slug', slug).eq('status', 'published').single();
if (!page) return new Response('Not found', { status: 404 });
const env = getEnv(Astro);
const url = new URL(Astro.url.pathname, env.PUBLIC_SITE_URL).toString();
---
<BaseLayout title={page.title} description={page.body.slice(0, 150)} lang={lang}>
  <PageHeader eyebrow="official wiki" title={page.title} description={`/${lang}/wiki/${page.slug}`} />
  <article class="prose-stellar terminal-panel max-w-none p-6">
    {page.body.split('\n').map((p: string) => <p>{p}</p>)}
  </article>
  <div class="mt-6"><ShareButtons client:load title={page.title} url={url} /></div>
</BaseLayout>
