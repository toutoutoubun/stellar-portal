---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
import { createSupabaseServer } from '@/lib/supabaseServer';
import { getWikiPage, getWikiPages, mergeWikiPages, wikiPageFromRecord, type WikiPage, type WikiPageRecord } from '@/lib/wiki';
const lang = normalizeLang(Astro.params.lang);
const basePages = getWikiPages(lang);
let editedPages: WikiPage[] = [];

try {
  const supabase = createSupabaseServer(Astro);
  const { data } = await supabase
    .from('wiki_pages')
    .select('slug,locale,title,body,updated_at')
    .eq('locale', lang)
    .eq('source_locale', lang)
    .eq('status', 'published')
    .order('slug');

  editedPages = (data ?? []).map((page) => wikiPageFromRecord(page as WikiPageRecord, lang, getWikiPage(lang, page.slug)));
} catch {
  editedPages = [];
}

const pages = mergeWikiPages(basePages, editedPages);
const categories = Array.from(new Set(pages.map((page) => page.category)));
---
<BaseLayout title="Wiki" lang={lang} description="Official Stellar documentation for installation, research workflows, analysis, data safety, troubleshooting, and contribution.">
  <PageHeader
    eyebrow="official documentation"
    title="Wiki"
    description="Official Stellar documentation. Practical guidance for installing, learning, troubleshooting, and contributing to the local-first desktop app."
  />

  <section class="mb-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {categories.map((category) => (
      <div class="border border-stellar-border bg-stellar-panel/70 p-4">
        <p class="font-mono text-xs uppercase tracking-[.14em] text-stellar-accent">{category}</p>
        <p class="mt-2 text-sm text-stellar-muted">
          {pages.filter((page) => page.category === category).length} docs
        </p>
      </div>
    ))}
  </section>

  <div class="grid gap-4 md:grid-cols-2">
    {pages.map((page) => (
      <article class="terminal-panel flex min-h-56 flex-col p-5">
        <div class="flex items-start justify-between gap-4">
          <p class="font-mono text-xs uppercase tracking-[.14em] text-stellar-accent">{page.category}</p>
          <time class="font-mono text-xs text-stellar-muted" datetime={page.updatedAt}>{page.updatedAt}</time>
        </div>
        <a href={`/${lang}/wiki/${page.slug}`} class="mt-4 font-mono text-xl leading-8 hover:text-stellar-accent">{page.title}</a>
        <p class="mt-3 line-clamp-3 leading-7 text-stellar-muted">{page.summary}</p>
        <a class="mt-auto pt-5 font-mono text-xs uppercase tracking-[.14em] text-stellar-accent" href={`/${lang}/wiki/${page.slug}`}>
          Read document
        </a>
      </article>
    ))}
  </div>
</BaseLayout>
