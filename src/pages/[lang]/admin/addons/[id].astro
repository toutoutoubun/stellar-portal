---
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import StatusBadge from '@/components/StatusBadge.astro';
import ReviewPanel from '@/components/ReviewPanel';
import { normalizeLang } from '@/lib/i18n';
import { requireUser, isReviewerOrAdmin } from '@/lib/access';
import { createSupabaseAdmin } from '@/lib/supabaseServer';
const lang = normalizeLang(Astro.params.lang);
const viewer = await requireUser(Astro);
if ('redirect' in viewer) return viewer.redirect;
if (!isReviewerOrAdmin(viewer.profile)) return new Response('Forbidden', { status: 403 });
const admin = createSupabaseAdmin(Astro);
const { data: addon } = await admin.from('addons').select('*, developer_profiles(*), profiles!addons_author_id_fkey(email, subscription_status, role)').eq('id', Astro.params.id).single();
const { data: logs } = await admin.from('moderation_logs').select('*').eq('target_type', 'addon').eq('target_id', Astro.params.id).order('created_at', { ascending: false });
if (!addon) return new Response('Not found', { status: 404 });
const warnings = [];
if (!addon.checksum) warnings.push('checksum is missing');
if (!addon.license) warnings.push('license is missing');
if ((addon.permissions ?? []).includes('network_access')) warnings.push('network_access declared');
if ((addon.permissions ?? []).includes('external_command')) warnings.push('external_command declared');
---
<AdminLayout title={`Review ${addon.name}`}>
  <PageHeader eyebrow="review target" title={addon.name} description={addon.short_description} />
  <div class="grid gap-6 lg:grid-cols-[1fr_360px]">
    <section class="terminal-panel grid gap-4 p-6">
      <div class="flex flex-wrap gap-2"><StatusBadge status={addon.review_status} lang={lang} /><StatusBadge status={addon.risk_level} lang={lang} /><StatusBadge status={addon.official_status} lang={lang} /></div>
      <dl class="grid gap-3 font-mono text-sm">
        <div><dt class="text-stellar-muted">author</dt><dd>{addon.developer_profiles?.display_name ?? 'unknown'} / {addon.profiles?.email}</dd></div>
        <div><dt class="text-stellar-muted">developer subscription</dt><dd>{addon.profiles?.subscription_status}</dd></div>
        <div><dt class="text-stellar-muted">repo_url</dt><dd class="break-all">{addon.repo_url}</dd></div>
        <div><dt class="text-stellar-muted">release_url</dt><dd class="break-all">{addon.release_url}</dd></div>
        <div><dt class="text-stellar-muted">checksum</dt><dd class="break-all">{addon.checksum}</dd></div>
        <div><dt class="text-stellar-muted">license</dt><dd>{addon.license}</dd></div>
        <div><dt class="text-stellar-muted">compatible</dt><dd>{addon.compatible_stellar_version}</dd></div>
        <div><dt class="text-stellar-muted">permissions</dt><dd class="mt-1 flex flex-wrap gap-1">{(addon.permissions ?? []).map((p: string) => <span class="badge">{p}</span>)}</dd></div>
      </dl>
      <div class="border border-stellar-border p-4">
        <p class="font-mono text-xs uppercase tracking-[.18em] text-stellar-accent">automatic checks</p>
        {warnings.length ? <ul class="mt-2 list-disc pl-5 text-stellar-muted">{warnings.map((w) => <li>{w}</li>)}</ul> : <p class="mt-2 text-stellar-muted">No obvious MVP warnings.</p>}
      </div>
      <div><h2 class="font-mono text-xl">Description</h2><p class="mt-3 leading-8 text-stellar-muted">{addon.description}</p></div>
    </section>
    <ReviewPanel client:load addonId={addon.id} currentStatus={addon.review_status} currentRisk={addon.risk_level} currentOfficial={addon.official_status} />
  </div>
  <section class="mt-6 terminal-panel p-6">
    <h2 class="font-mono text-xl">Moderation logs</h2>
    <div class="mt-4 grid gap-3">{(logs ?? []).map((log) => <div class="border border-stellar-border p-3 text-sm text-stellar-muted"><p class="font-mono text-stellar-text">{log.action} / {log.created_at}</p><p>{log.note}</p></div>)}</div>
  </section>
</AdminLayout>
