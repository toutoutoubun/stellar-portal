---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import AdminAddonReviewForm from '@/components/AdminAddonReviewForm';
import { normalizeLang } from '@/lib/i18n';
import { requireAdminPage } from '@/lib/admin';

export const prerender = false;

const lang = normalizeLang(Astro.params.lang);
const id = Astro.params.id;

const guard = await requireAdminPage(Astro, lang);

if (!guard.ok) {
  return Astro.redirect(guard.redirect);
}

if (!id) {
  return Astro.redirect(`/${lang}/admin/review`);
}

const { data: addon } = await guard.admin
  .from('addons')
  .select('*')
  .eq('id', id)
  .single();

if (!addon) {
  return Astro.redirect(`/${lang}/admin/review`);
}

const [{ data: author }, { data: developerProfile }, { data: versions }, { data: logs }] = await Promise.all([
  guard.admin.from('profiles').select('id,email,display_name,role,subscription_status').eq('id', addon.author_id).maybeSingle(),
  addon.developer_profile_id
    ? guard.admin.from('developer_profiles').select('*').eq('id', addon.developer_profile_id).maybeSingle()
    : Promise.resolve({ data: null }),
  guard.admin.from('addon_versions').select('*').eq('addon_id', addon.id).order('created_at', { ascending: false }),
  guard.admin.from('moderation_logs').select('*').eq('target_type', 'addon').eq('target_id', addon.id).order('created_at', { ascending: false })
]);

function formatDate(value: string | null) {
  if (!value) return '—';
  return new Date(value).toLocaleString('ja-JP');
}

function asList(value: unknown) {
  if (!value) return [];
  if (Array.isArray(value)) return value;
  if (typeof value === 'string') return value.split(',').map((item) => item.trim()).filter(Boolean);
  return [];
}
---

<DashboardLayout title={`Review ${addon.name}`}>
  <PageHeader
    eyebrow="addon inspection"
    title={addon.name}
    description={addon.short_description ?? 'Review community-submitted addon metadata, risk, permissions, and release links.'}
  />

  <section class="grid gap-6 xl:grid-cols-[1fr_380px]">
    <div class="grid gap-6">
      <div class="terminal-panel p-5">
        <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">metadata</p>

        <dl class="mt-4 grid gap-4 md:grid-cols-2">
          <div>
            <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Slug</dt>
            <dd class="mt-1 text-stellar-text">{addon.slug}</dd>
          </div>

          <div>
            <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Version</dt>
            <dd class="mt-1 text-stellar-text">{addon.current_version}</dd>
          </div>

          <div>
            <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">License</dt>
            <dd class="mt-1 text-stellar-text">{addon.license}</dd>
          </div>

          <div>
            <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Compatible Stellar</dt>
            <dd class="mt-1 text-stellar-text">{addon.compatible_stellar_version}</dd>
          </div>

          <div>
            <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Checksum</dt>
            <dd class="mt-1 break-all font-mono text-xs text-stellar-text">{addon.checksum}</dd>
          </div>

          <div>
            <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Submitted</dt>
            <dd class="mt-1 text-stellar-text">{formatDate(addon.created_at)}</dd>
          </div>
        </dl>

        <div class="mt-6">
          <p class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Description</p>
          <p class="mt-2 whitespace-pre-wrap text-stellar-text">{addon.description}</p>
        </div>

        <div class="mt-6 grid gap-2">
          {addon.repo_url && <a class="text-stellar-accent hover:underline" href={addon.repo_url} target="_blank">Repository</a>}
          {addon.release_url && <a class="text-stellar-accent hover:underline" href={addon.release_url} target="_blank">Release URL</a>}
          {addon.documentation_url && <a class="text-stellar-accent hover:underline" href={addon.documentation_url} target="_blank">Documentation</a>}
        </div>
      </div>

      <div class="terminal-panel p-5">
        <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">permissions</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {asList(addon.permissions).length === 0 && <p class="text-stellar-muted">No permissions listed.</p>}
          {asList(addon.permissions).map((permission) => (
            <span class="border border-stellar-border px-2 py-1 font-mono text-xs text-stellar-muted">
              {permission}
            </span>
          ))}
        </div>
      </div>

      <div class="terminal-panel p-5">
        <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">author</p>
        <div class="mt-4 grid gap-2">
          <p class="text-stellar-text">{developerProfile?.display_name ?? author?.display_name ?? author?.email ?? 'Unknown author'}</p>
          <p class="font-mono text-xs text-stellar-muted">{author?.email}</p>
          <p class="font-mono text-xs text-stellar-muted">role: {author?.role ?? 'unknown'} / subscription: {author?.subscription_status ?? 'unknown'}</p>
        </div>
      </div>

      <div class="terminal-panel p-5">
        <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">versions</p>
        <div class="mt-4 grid gap-3">
          {(versions ?? []).length === 0 && <p class="text-stellar-muted">No version records.</p>}
          {(versions ?? []).map((version) => (
            <div class="border border-stellar-border bg-stellar-panel2 p-3">
              <p class="font-mono text-sm text-stellar-text">{version.version}</p>
              <p class="mt-1 text-sm text-stellar-muted">{version.changelog}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <aside class="grid gap-6 self-start">
      <AdminAddonReviewForm
        client:load
        addonId={addon.id}
        initialReviewStatus={addon.review_status}
        initialRiskLevel={addon.risk_level}
        initialOfficialStatus={addon.official_status}
      />

      <div class="terminal-panel p-5">
        <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">moderation logs</p>
        <div class="mt-4 grid gap-3">
          {(logs ?? []).length === 0 && <p class="text-stellar-muted">No logs.</p>}
          {(logs ?? []).map((log) => (
            <div class="border border-stellar-border bg-stellar-panel2 p-3">
              <p class="font-mono text-xs uppercase text-stellar-accent">{log.action}</p>
              <p class="mt-1 text-xs text-stellar-muted">{formatDate(log.created_at)}</p>
              {log.note && <p class="mt-2 text-sm text-stellar-text">{log.note}</p>}
            </div>
          ))}
        </div>
      </div>
    </aside>
  </section>
</DashboardLayout>
