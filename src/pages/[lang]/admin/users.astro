---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import AdminUserActions from '@/components/AdminUserActions';
import { normalizeLang } from '@/lib/i18n';
import { requireAdminPage } from '@/lib/admin';

export const prerender = false;

const lang = normalizeLang(Astro.params.lang);
const guard = await requireAdminPage(Astro, lang);

if (!guard.ok) {
  return Astro.redirect(guard.redirect);
}

if (guard.viewer.profile?.role !== 'admin') {
  return Astro.redirect(`/${lang}/admin`);
}

const { data: users } = await guard.admin
  .from('profiles')
  .select('id,email,display_name,role,subscription_status,stripe_customer_id,created_at,updated_at')
  .order('created_at', { ascending: false })
  .limit(100);

function formatDate(value: string | null) {
  if (!value) return '—';
  return new Date(value).toLocaleString('ja-JP');
}
---

<DashboardLayout title="Users">
  <PageHeader
    eyebrow="identity registry"
    title="User Management"
    description="Manage roles and developer access. Paid developer registration is still separate from publication approval."
  />

  <div class="terminal-panel overflow-x-auto p-5">
    <table class="w-full min-w-[980px] border-collapse text-left text-sm">
      <thead class="border-b border-stellar-border font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">
        <tr>
          <th class="py-3 pr-4">User</th>
          <th class="py-3 pr-4">Role</th>
          <th class="py-3 pr-4">Subscription</th>
          <th class="py-3 pr-4">Stripe</th>
          <th class="py-3 pr-4">Created</th>
          <th class="py-3 pr-4">Actions</th>
        </tr>
      </thead>
      <tbody>
        {(users ?? []).map((user) => (
          <tr class="border-b border-stellar-border/70 align-top">
            <td class="py-4 pr-4">
              <p class="text-stellar-text">{user.display_name ?? user.email}</p>
              <p class="font-mono text-xs text-stellar-muted">{user.email}</p>
              <p class="font-mono text-xs text-stellar-muted">{user.id}</p>
            </td>
            <td class="py-4 pr-4 font-mono text-xs uppercase">{user.role}</td>
            <td class="py-4 pr-4 font-mono text-xs uppercase">{user.subscription_status}</td>
            <td class="py-4 pr-4 font-mono text-xs text-stellar-muted">{user.stripe_customer_id ?? '—'}</td>
            <td class="py-4 pr-4 text-stellar-muted">{formatDate(user.created_at)}</td>
            <td class="py-4 pr-4">
              <AdminUserActions
                client:load
                userId={user.id}
                initialRole={user.role}
                initialSubscriptionStatus={user.subscription_status}
              />
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</DashboardLayout>
