---
import AdminLayout from '@/layouts/AdminLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
import { requireUser, isReviewerOrAdmin } from '@/lib/access';
const lang = normalizeLang(Astro.params.lang);
const viewer = await requireUser(Astro);
if ('redirect' in viewer) return viewer.redirect;
if (!isReviewerOrAdmin(viewer.profile)) return new Response('Forbidden', { status: 403 });
---
<AdminLayout title="Admin">
  <PageHeader eyebrow="moderation desk" title="Admin" description="Review submitted addons, manage risk labels, and suspend unsafe listings." />
  <a class="btn btn-primary" href={`/${lang}/admin/review`}>Open review queue</a>
</AdminLayout>
