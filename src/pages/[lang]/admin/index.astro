---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
import { requireAdminPage } from '@/lib/admin';

export const prerender = false;

const lang = normalizeLang(Astro.params.lang);
const guard = await requireAdminPage(Astro, lang);

if (!guard.ok) {
  return Astro.redirect(guard.redirect);
}

const admin = guard.admin;

const [
  pendingAddonsResult,
  approvedAddonsResult,
  suspendedAddonsResult,
  usersResult,
  developersResult,
  reportsResult,
  recentPendingResult,
  recentLogsResult,
  highRiskResult
] = await Promise.all([
  admin.from('addons').select('id', { count: 'exact', head: true }).eq('review_status', 'pending'),
  admin.from('addons').select('id', { count: 'exact', head: true }).eq('review_status', 'approved'),
  admin.from('addons').select('id', { count: 'exact', head: true }).eq('review_status', 'suspended'),
  admin.from('profiles').select('id', { count: 'exact', head: true }),
  admin.from('profiles').select('id', { count: 'exact', head: true }).in('role', ['developer', 'reviewer', 'admin']),
  admin.from('reports').select('id', { count: 'exact', head: true }).eq('status', 'open'),
  admin
    .from('addons')
    .select('id, name, slug, review_status, official_status, risk_level, created_at, repo_url, release_url')
    .eq('review_status', 'pending')
    .order('created_at', { ascending: false })
    .limit(6),
  admin
    .from('moderation_logs')
    .select('id, target_type, target_id, action, note, created_at')
    .order('created_at', { ascending: false })
    .limit(8),
  admin
    .from('addons')
    .select('id, name, slug, risk_level, review_status, created_at')
    .in('risk_level', ['high', 'unknown'])
    .order('created_at', { ascending: false })
    .limit(6)
]);

const stats = [
  { label: 'Pending addons', value: pendingAddonsResult.count ?? 0, href: `/${lang}/admin/review`, note: '審査待ち' },
  { label: 'Published addons', value: approvedAddonsResult.count ?? 0, href: `/${lang}/addons`, note: '公開中' },
  { label: 'Suspended addons', value: suspendedAddonsResult.count ?? 0, href: `/${lang}/admin/review`, note: '停止中' },
  { label: 'Users', value: usersResult.count ?? 0, href: `/${lang}/admin/users`, note: '登録ユーザー' },
  { label: 'Developers', value: developersResult.count ?? 0, href: `/${lang}/admin/users`, note: 'Developer以上' },
  { label: 'Open reports', value: reportsResult.count ?? 0, href: `/${lang}/admin/reports`, note: '未対応通報' }
];

const recentPending = recentPendingResult.data ?? [];
const recentLogs = recentLogsResult.data ?? [];
const highRiskAddons = highRiskResult.data ?? [];

function formatDate(value: string | null) {
  if (!value) return '—';
  return new Date(value).toLocaleString('ja-JP');
}
---

<DashboardLayout title="Admin">
  <PageHeader
    eyebrow="control room"
    title="Admin Dashboard"
    description="Review submissions, monitor risk signals, and keep community addons separate from official documentation."
  />

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {stats.map((stat) => (
      <a href={stat.href} class="terminal-panel block p-5 transition hover:border-stellar-accent">
        <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">{stat.label}</p>
        <p class="mt-4 font-mono text-4xl text-stellar-text">{stat.value}</p>
        <p class="mt-2 text-sm text-stellar-muted">{stat.note}</p>
      </a>
    ))}
  </section>

  <section class="mt-8 grid gap-6 xl:grid-cols-[1.35fr_.65fr]">
    <div class="terminal-panel p-5">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">review queue</p>
          <h2 class="mt-2 text-2xl text-stellar-text">Pending addon submissions</h2>
        </div>
        <a class="btn" href={`/${lang}/admin/review`}>Open review desk</a>
      </div>

      <div class="mt-5 grid gap-3">
        {recentPending.length === 0 && <p class="text-stellar-muted">審査待ちはありません。</p>}
        {recentPending.map((addon) => (
          <a href={`/${lang}/admin/addons/${addon.id}`} class="block border border-stellar-border bg-stellar-panel2 p-4 hover:border-stellar-accent">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="text-stellar-text">{addon.name}</p>
                <p class="font-mono text-xs text-stellar-muted">{addon.slug}</p>
              </div>
              <div class="flex gap-2 font-mono text-xs uppercase">
                <span class="border border-stellar-border px-2 py-1">{addon.review_status}</span>
                <span class="border border-stellar-border px-2 py-1">{addon.risk_level}</span>
              </div>
            </div>
            <p class="mt-2 text-sm text-stellar-muted">{formatDate(addon.created_at)}</p>
          </a>
        ))}
      </div>
    </div>

    <aside class="grid gap-6">
      <div class="terminal-panel p-5">
        <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">risk watch</p>
        <h2 class="mt-2 text-xl text-stellar-text">High / unknown risk</h2>
        <div class="mt-4 grid gap-3">
          {highRiskAddons.length === 0 && <p class="text-sm text-stellar-muted">高リスクまたは未判定のアドオンはありません。</p>}
          {highRiskAddons.map((addon) => (
            <a href={`/${lang}/admin/addons/${addon.id}`} class="block border border-stellar-border bg-stellar-panel2 p-3 hover:border-stellar-accent">
              <p class="text-stellar-text">{addon.name}</p>
              <p class="mt-1 font-mono text-xs text-stellar-muted">{addon.risk_level} / {addon.review_status}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="terminal-panel p-5">
        <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">admin routes</p>
        <div class="mt-4 grid gap-2">
          <a class="btn justify-start" href={`/${lang}/admin/review`}>Review queue</a>
          <a class="btn justify-start" href={`/${lang}/admin/users`}>Users</a>
          <a class="btn justify-start" href={`/${lang}/admin/reports`}>Reports</a>
          <a class="btn justify-start" href={`/${lang}/safety`}>Safety policy</a>
        </div>
      </div>
    </aside>
  </section>

  <section class="terminal-panel mt-8 p-5">
    <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">moderation log</p>
    <h2 class="mt-2 text-2xl text-stellar-text">Recent actions</h2>

    <div class="mt-5 grid gap-3">
      {recentLogs.length === 0 && <p class="text-stellar-muted">まだ審査ログはありません。</p>}
      {recentLogs.map((log) => (
        <div class="border border-stellar-border bg-stellar-panel2 p-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <p class="font-mono text-xs uppercase tracking-[.18em] text-stellar-accent">{log.action}</p>
            <p class="font-mono text-xs text-stellar-muted">{formatDate(log.created_at)}</p>
          </div>
          <p class="mt-2 text-sm text-stellar-muted">{log.target_type} / {log.target_id}</p>
          {log.note && <p class="mt-3 text-stellar-text">{log.note}</p>}
        </div>
      ))}
    </div>
  </section>
</DashboardLayout>
