---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import AdminAssetReviewForm from '@/components/AdminAssetReviewForm';
import AdminAssetStorageActions from '@/components/AdminAssetStorageActions';
import AdminAssetSafetyScan from '@/components/AdminAssetSafetyScan';
import { normalizeLang } from '@/lib/i18n';
import { requireAdminPage } from '@/lib/admin';

export const prerender = false;

const lang = normalizeLang(Astro.params.lang);
const guard = await requireAdminPage(Astro, lang);

if (!guard.ok) {
  return Astro.redirect(guard.redirect);
}

const status = Astro.url.searchParams.get('status') ?? 'pending';

let query = guard.admin
  .from('addon_assets')
  .select(`
    id,
    addon_id,
    uploader_id,
    version,
    file_name,
    object_key,
    content_type,
    byte_size,
    checksum,
    review_status,
    review_note,
    reviewed_at,
    storage_status,
    safety_status,
    safety_summary,
    safety_checked_at,
    deleted_at,
    deleted_reason,
    created_at,
    addons (
      id,
      name,
      slug,
      review_status,
      official_status,
      risk_level
    )
  `)
  .order('created_at', { ascending: false })
  .limit(100);

if (status !== 'all') {
  query = query.eq('review_status', status);
}

const { data: assets } = await query;

function formatDate(value: string | null) {
  if (!value) return '—';
  return new Date(value).toLocaleString('ja-JP');
}

function formatSize(value: number | null) {
  if (!value) return '—';
  if (value < 1024 * 1024) return `${Math.round(value / 1024)} KB`;
  return `${Math.round(value / 1024 / 1024)} MB`;
}

function firstRelation<T>(value: T | T[] | null | undefined): T | null {
  if (Array.isArray(value)) return value[0] ?? null;
  return value ?? null;
}
---

<DashboardLayout title="Asset Review">
  <PageHeader
    eyebrow="binary inspection"
    title="Addon Asset Review"
    description="Approve or reject uploaded addon files before they become downloadable from the public catalog."
  />

  <div class="mb-5 flex flex-wrap gap-2">
    {['pending', 'approved', 'rejected', 'suspended', 'all'].map((item) => (
      <a
        class={`btn ${status === item ? 'btn-primary' : ''}`}
        href={`/${lang}/admin/assets?status=${item}`}
      >
        {item}
      </a>
    ))}
  </div>

  <div class="grid gap-4">
    {(assets ?? []).length === 0 && (
      <div class="terminal-panel p-5 text-stellar-muted">
        対象アセットはありません。
      </div>
    )}

    {(assets ?? []).map((asset) => (
      <article class="terminal-panel grid gap-5 p-5 xl:grid-cols-[1fr_360px]">
        <div>
          <div class="flex flex-wrap items-center gap-2">
            <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
              {asset.review_status}
            </span>
            <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
              {asset.content_type ?? 'unknown'}
            </span>
            <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
              {formatSize(asset.byte_size)}
            </span>
          </div>

          <h2 class="mt-4 text-xl text-stellar-text">
            {asset.file_name}
          </h2>

          <p class="mt-1 font-mono text-xs text-stellar-muted">
            version: {asset.version}
          </p>

          <p class="mt-3 text-stellar-muted">
            Addon:
            {' '}
            <a class="text-stellar-accent hover:underline" href={`/${lang}/admin/addons/${asset.addon_id}`}>
              {firstRelation(asset.addons)?.name ?? asset.addon_id}
            </a>
          </p>

          <dl class="mt-4 grid gap-3 text-sm">
            <div>
              <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Checksum</dt>
              <dd class="mt-1 break-all font-mono text-xs text-stellar-text">{asset.checksum}</dd>
            </div>

            <div>
              <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Object key</dt>
              <dd class="mt-1 break-all font-mono text-xs text-stellar-muted">{asset.object_key}</dd>
            </div>

            <div>
              <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Uploaded</dt>
              <dd class="mt-1 text-stellar-muted">{formatDate(asset.created_at)}</dd>
            </div>

            {asset.review_note && (
              <div>
                <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Review note</dt>
                <dd class="mt-1 text-stellar-text">{asset.review_note}</dd>
              </div>
            )}
          </dl>
        </div>

        <div class="grid gap-4">
          <AdminAssetSafetyScan
            client:load
            assetId={asset.id}
            initialSafetyStatus={asset.safety_status ?? 'unchecked'}
            initialSafetySummary={asset.safety_summary ?? null}
          />

          <AdminAssetReviewForm
            client:load
            assetId={asset.id}
            initialStatus={asset.review_status}
          />

          <AdminAssetStorageActions
            client:load
            assetId={asset.id}
            storageStatus={asset.storage_status ?? 'active'}
          />
        </div>
      </article>
    ))}
  </div>
</DashboardLayout>
