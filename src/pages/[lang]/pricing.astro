---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
import { getPublicCopy } from '@/lib/publicCopy';
import BillingButtons from '@/components/BillingButtons';
const lang = normalizeLang(Astro.params.lang);
const copy = getPublicCopy(lang);
---
<BaseLayout title={copy.pricing.title} lang={lang} description={copy.pricing.description}>
  <PageHeader eyebrow={copy.portalEyebrow} title={copy.pricing.title} description={copy.pricing.description} />
  <div class="terminal-panel grid gap-5 p-6">
    <h2 class="font-mono text-2xl">{copy.pricing.planTitle}</h2>
    <p class="leading-8 text-stellar-muted">{copy.pricing.body}</p>
    <BillingButtons client:load lang={lang} mode="checkout" />
  </div>
</BaseLayout>
