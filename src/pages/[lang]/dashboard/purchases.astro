---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
import { getViewer } from '@/lib/access';
import { createSupabaseAdmin } from '@/lib/supabaseServer';

export const prerender = false;

const lang = normalizeLang(Astro.params.lang);
const viewer = await getViewer(Astro);

if (!viewer.user) {
  return Astro.redirect(`/${lang}/login`);
}

const admin = createSupabaseAdmin();

const { data: purchases } = await admin
  .from('addon_purchases')
  .select(`
    id,
    addon_id,
    amount_total,
    currency,
    status,
    purchased_at,
    created_at,
    addons (
      id,
      name,
      slug,
      short_description,
      review_status
    )
  `)
  .eq('user_id', viewer.user.id)
  .order('created_at', { ascending: false });

function formatDate(value: string | null) {
  if (!value) return '—';
  return new Date(value).toLocaleString('ja-JP');
}

function formatPrice(value: number | null, currency: string | null) {
  if (!value) return '—';
  if ((currency ?? 'jpy') === 'jpy') return `¥${value.toLocaleString('ja-JP')}`;
  return `${value} ${currency}`;
}

function firstRelation<T>(value: T | T[] | null | undefined): T | null {
  if (Array.isArray(value)) return value[0] ?? null;
  return value ?? null;
}
---

<DashboardLayout title="Purchases">
  <PageHeader
    eyebrow="purchase ledger"
    title="Purchased Addons"
    description="Downloaded and purchased addons attached to this account."
  />

  <div class="grid gap-4">
    {(purchases ?? []).length === 0 && (
      <div class="terminal-panel p-5 text-stellar-muted">
        まだ購入済みアドオンはありません。
      </div>
    )}

    {(purchases ?? []).map((purchase) => (
      <article class="terminal-panel grid gap-4 p-5 md:grid-cols-[1fr_auto]">
        <div>
          <div class="flex flex-wrap gap-2">
            <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
              {purchase.status}
            </span>
            <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
              {formatPrice(purchase.amount_total, purchase.currency)}
            </span>
          </div>

          <h2 class="mt-4 text-xl text-stellar-text">
            {firstRelation(purchase.addons)?.name ?? purchase.addon_id}
          </h2>

          <p class="mt-2 text-stellar-muted">
            {firstRelation(purchase.addons)?.short_description}
          </p>

          <p class="mt-3 font-mono text-xs text-stellar-muted">
            purchased: {formatDate(purchase.purchased_at ?? purchase.created_at)}
          </p>
        </div>

        <div class="flex items-center gap-2">
          {firstRelation(purchase.addons)?.slug && (
            <a class="btn" href={`/${lang}/addons/${firstRelation(purchase.addons)?.slug}`}>
              Detail
            </a>
          )}

          {purchase.status === 'paid' && (
            <a class="btn btn-primary" href={`/api/addons/${purchase.addon_id}/download`}>
              Download
            </a>
          )}
        </div>
      </article>
    ))}
  </div>
</DashboardLayout>
