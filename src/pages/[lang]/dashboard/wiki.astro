---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import WikiEditorForm from '@/components/WikiEditorForm';
import { getViewer, hasWikiEditAccess } from '@/lib/access';
import { normalizeLang } from '@/lib/i18n';
import { createSupabaseServer } from '@/lib/supabaseServer';

const lang = normalizeLang(Astro.params.lang);
type EditableWikiPage = {
  slug: string;
  locale: string;
  title: string;
  body: string;
  status: string;
  updated_at?: string | null;
};

let viewer = {
  user: null as any,
  profile: null as any
};
let authError = '';
let pages: EditableWikiPage[] = [];

try {
  viewer = await getViewer(Astro);

  if (viewer.user && hasWikiEditAccess(viewer.profile)) {
    const supabase = createSupabaseServer(Astro);
    const { data } = await supabase
      .from('wiki_pages')
      .select('slug,locale,title,body,status,updated_at')
      .order('locale')
      .order('slug');
    pages = data ?? [];
  }
} catch (error) {
  authError = error instanceof Error ? error.message : 'Unknown auth error';
}
---
<DashboardLayout title="Wiki Editor">
  <PageHeader
    eyebrow="developer console"
    title="Wiki Editor"
    description="Active paid users can create and update DB-backed Wiki pages for all four locales."
  />

  {authError && (
    <div class="terminal-panel mb-6 border-stellar-danger/60 p-5 text-stellar-text">
      <p class="mb-2 font-mono text-xs uppercase tracking-[.18em] text-stellar-danger">auth not connected</p>
      <p>{authError}</p>
    </div>
  )}

  {!viewer.user && !authError && (
    <div class="terminal-panel p-5">
      <p class="text-stellar-muted">Wiki編集にはログインが必要です。</p>
      <a class="btn mt-4 inline-flex" href={`/${lang}/login`}>Login</a>
    </div>
  )}

  {viewer.user && !hasWikiEditAccess(viewer.profile) && (
    <div class="terminal-panel p-5">
      <p class="font-mono text-xs uppercase tracking-[.18em] text-stellar-accent">Developer Plan required</p>
      <p class="mt-3 leading-7 text-stellar-muted">課金状態がactiveまたはtrialingのユーザー、またはDeveloper/Reviewer/Admin roleのユーザーだけがWikiを編集できます。</p>
      <a class="btn mt-4 inline-flex" href={`/${lang}/pricing`}>Open pricing</a>
    </div>
  )}

  {viewer.user && hasWikiEditAccess(viewer.profile) && (
    <WikiEditorForm client:load lang={lang} pages={pages} />
  )}
</DashboardLayout>
