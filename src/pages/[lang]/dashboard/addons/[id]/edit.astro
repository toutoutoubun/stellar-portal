---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import AddonForm from '@/components/AddonForm';
import { normalizeLang } from '@/lib/i18n';
import { requireUser } from '@/lib/access';
import { createSupabaseServer } from '@/lib/supabaseServer';
const lang = normalizeLang(Astro.params.lang);
const viewer = await requireUser(Astro);
if ('redirect' in viewer) return viewer.redirect;
const supabase = createSupabaseServer(Astro);
const { data: addon } = await supabase.from('addons').select('*').eq('id', Astro.params.id).single();
if (!addon) return new Response('Not found', { status: 404 });
---
<DashboardLayout title="Edit Addon">
  <PageHeader eyebrow="submission" title={`Edit: ${addon.name}`} description="Saving changes returns the addon to pending review unless staff changes the final status." />
  <AddonForm client:load addon={addon} lang={lang} />
</DashboardLayout>
