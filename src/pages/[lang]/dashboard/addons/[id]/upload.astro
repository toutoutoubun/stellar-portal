---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import AddonAssetUpload from '@/components/AddonAssetUpload';
import AddonSalesSettings from '@/components/AddonSalesSettings';
import AddonManifestImport from '@/components/AddonManifestImport';
import { normalizeLang } from '@/lib/i18n';
import { getViewer } from '@/lib/access';
import { createSupabaseAdmin } from '@/lib/supabaseServer';

export const prerender = false;

const lang = normalizeLang(Astro.params.lang);
const id = Astro.params.id;

const viewer = await getViewer(Astro);

if (!viewer.user) {
  return Astro.redirect(`/${lang}/login`);
}

if (!id) {
  return Astro.redirect(`/${lang}/dashboard/addons`);
}

const admin = createSupabaseAdmin();

const { data: addon } = await admin
  .from('addons')
  .select('*')
  .eq('id', id)
  .single();

if (!addon) {
  return Astro.redirect(`/${lang}/dashboard/addons`);
}

const role = viewer.profile?.role ?? 'free_user';
const canEdit = addon.author_id === viewer.user.id || role === 'admin' || role === 'reviewer';

if (!canEdit) {
  return Astro.redirect(`/${lang}/dashboard/addons`);
}

const { data: assets } = await admin
  .from('addon_assets')
  .select('*')
  .eq('addon_id', addon.id)
  .order('created_at', { ascending: false });

function formatDate(value: string | null) {
  if (!value) return '—';
  return new Date(value).toLocaleString('ja-JP');
}
---

<DashboardLayout title="Upload addon asset">
  <PageHeader
    eyebrow="developer upload"
    title={`Upload: ${addon.name}`}
    description="Upload addon release files to Cloudflare R2. Uploaded files remain pending until reviewed."
  />

  <section class="grid gap-6 xl:grid-cols-[420px_1fr]">
    <div class="grid gap-6">
      <AddonAssetUpload
        client:load
        addonId={addon.id}
        defaultVersion={addon.current_version ?? '0.1.0'}
      />

      <AddonSalesSettings
        client:load
        addonId={addon.id}
        initialIsPaid={Boolean(addon.is_paid)}
        initialPriceJpy={addon.price_jpy ?? null}
        initialSalesStatus={addon.sales_status ?? 'not_for_sale'}
      />

      <AddonManifestImport
        client:load
        addonId={addon.id}
      />
    </div>

    <div class="terminal-panel p-5">
      <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">
        uploaded assets
      </p>

      <div class="mt-4 grid gap-3">
        {(assets ?? []).length === 0 && (
          <p class="text-stellar-muted">まだアップロードはありません。</p>
        )}

        {(assets ?? []).map((asset) => (
          <div class="border border-stellar-border bg-stellar-panel2 p-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="text-stellar-text">{asset.file_name}</p>
                <p class="font-mono text-xs text-stellar-muted">{asset.version}</p>
              </div>
              <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
                {asset.review_status}
              </span>
            </div>

            <dl class="mt-3 grid gap-2 text-sm">
              <div>
                <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Checksum</dt>
                <dd class="break-all font-mono text-xs text-stellar-text">{asset.checksum}</dd>
              </div>
              <div>
                <dt class="font-mono text-xs uppercase tracking-[.18em] text-stellar-muted">Uploaded</dt>
                <dd class="text-stellar-muted">{formatDate(asset.created_at)}</dd>
              </div>
            </dl>
          </div>
        ))}
      </div>
    </div>
  </section>
</DashboardLayout>
