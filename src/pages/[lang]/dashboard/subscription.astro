---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import BillingButtons from '@/components/BillingButtons';
import { normalizeLang } from '@/lib/i18n';
import { requireUser } from '@/lib/access';
const lang = normalizeLang(Astro.params.lang);
const copy = {
  ja: { eyebrow: '開発者コンソール', title: '契約', description: '開発者プランの状態はStripe Webhookから同期されます。', status: '契約状態' },
  en: { eyebrow: 'developer console', title: 'Subscription', description: 'Developer Plan state is synchronized from Stripe Webhooks.', status: 'subscription_status' },
  fr: { eyebrow: 'console développeur', title: 'Abonnement', description: 'L’état du plan développeur est synchronisé depuis les webhooks Stripe.', status: 'statut_abonnement' },
  af: { eyebrow: 'ontwikkelaarskonsole', title: 'Intekening', description: 'Die ontwikkelaarsplanstatus word vanaf Stripe-webhooks gesinchroniseer.', status: 'intekeningstatus' }
}[lang];
const viewer = await requireUser(Astro);
if ('redirect' in viewer) return viewer.redirect;
---
<DashboardLayout title={copy.title}>
  <PageHeader eyebrow={copy.eyebrow} title={copy.title} description={copy.description} />
  <div class="terminal-panel grid gap-3 p-6 font-mono text-sm">
    <p>{copy.status}: {viewer.profile?.subscription_status}</p>
    <BillingButtons client:load lang={lang} mode="portal" />
  </div>
</DashboardLayout>
