---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import LoginForm from '@/components/LoginForm';
import { normalizeLang } from '@/lib/i18n';
import { getPublicCopy } from '@/lib/publicCopy';
import { getEnv } from '@/lib/env';

const lang = normalizeLang(Astro.params.lang);
const copy = getPublicCopy(lang);
const env = getEnv();

const supabaseUrl = env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = env.PUBLIC_SUPABASE_ANON_KEY;
---

<BaseLayout title={copy.login.title} lang={lang} description={copy.login.description}>
  <PageHeader
    eyebrow={copy.login.eyebrow}
    title={copy.login.title}
    description={copy.login.description}
  />

  {!supabaseUrl || !supabaseAnonKey ? (
    <div class="terminal-panel border border-stellar-danger/60 bg-stellar-danger/10 p-6 text-stellar-text">
      <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-danger">
        {copy.login.supabaseMissing}
      </p>
      <p class="mt-3">
        {copy.login.supabaseMessage}
      </p>
    </div>
  ) : (
    <div class="max-w-xl">
      <LoginForm
        client:load
        lang={lang}
        supabaseUrl={supabaseUrl}
        supabaseAnonKey={supabaseAnonKey}
      />
    </div>
  )}
</BaseLayout>
