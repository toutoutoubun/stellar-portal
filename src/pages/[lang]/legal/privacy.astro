---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
import { getPublicCopy } from '@/lib/publicCopy';
const lang = normalizeLang(Astro.params.lang);
const copy = getPublicCopy(lang);
---
<BaseLayout title={copy.legal.privacyTitle} lang={lang} description={copy.legal.commonDescription}>
  <PageHeader eyebrow={copy.legal.eyebrow} title={copy.legal.privacyTitle} description={copy.legal.commonDescription} />
  <article class="terminal-panel prose-stellar p-6">
    <p>{copy.legal.commonBody}</p>
    <p>{copy.legal.reviewNotice}</p>
  </article>
</BaseLayout>
