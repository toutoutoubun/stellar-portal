---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
const lang = normalizeLang(Astro.params.lang);
---
<BaseLayout title="Terms of Service" lang={lang}>
  <PageHeader eyebrow="legal" title="Terms of Service" description="MVP placeholder. Replace with reviewed legal text before public launch." />
  <article class="terminal-panel prose-stellar p-6">
    <p>This is a placeholder for Terms of Service. Before launch, replace this page with jurisdiction-appropriate legal text.</p>
    <p>Addon publication is reviewed. Developer registration does not guarantee approval, ranking, or official status.</p>
  </article>
</BaseLayout>
