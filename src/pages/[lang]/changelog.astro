---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { normalizeLang } from '@/lib/i18n';
const lang = normalizeLang(Astro.params.lang);
---
<BaseLayout title="Changelog" lang={lang}>
  <PageHeader eyebrow="stellar portal" title="Changelog" description="Stellar and Portal release notes." />
  <div class="terminal-panel prose-stellar p-6">
    <p>Stellar and Portal release notes.</p>
  </div>
</BaseLayout>
