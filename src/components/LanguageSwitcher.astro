---
import { languages, languageNames, localizePath, type Lang } from '@/lib/i18n';
const { lang } = Astro.props as { lang: Lang };
---
<div class="flex gap-1">
  {languages.map((next) => (
    <a
      aria-current={next === lang ? 'page' : undefined}
      class:list={['rounded-full border px-2 py-1 text-[10px]', next === lang ? 'border-stellar-accent bg-stellar-accent text-white' : 'border-stellar-border text-stellar-muted hover:border-stellar-accent']}
      href={localizePath(Astro.url.pathname, next)}
      title={languageNames[next]}
    >{next}</a>
  ))}
</div>
