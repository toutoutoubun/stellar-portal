---
type Props = {
  reviewStatus?: string | null;
  riskLevel?: string | null;
  officialStatus?: string | null;
  safetyStatus?: string | null;
  safetySummary?: string | null;
  safetyCheckedAt?: string | null;
};

const {
  reviewStatus,
  riskLevel,
  officialStatus,
  safetyStatus,
  safetySummary,
  safetyCheckedAt
} = Astro.props;

function statusLabel(value: string | null | undefined) {
  return value ?? 'unknown';
}

function formatDate(value: string | null | undefined) {
  if (!value) return '—';
  return new Date(value).toLocaleString('ja-JP');
}

function classForSafety(value: string | null | undefined) {
  if (value === 'pass') return 'border-stellar-accent text-stellar-accent';
  if (value === 'warning') return 'border-stellar-accent text-stellar-accent';
  if (value === 'fail' || value === 'error') return 'border-stellar-danger text-stellar-danger';
  return 'border-stellar-border text-stellar-muted';
}
---

<section class="terminal-panel p-5">
  <p class="font-mono text-xs uppercase tracking-[.22em] text-stellar-muted">
    safety record
  </p>

  <div class="mt-4 flex flex-wrap gap-2">
    <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
      review: {statusLabel(reviewStatus)}
    </span>

    <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
      official: {statusLabel(officialStatus)}
    </span>

    <span class="border border-stellar-border px-2 py-1 font-mono text-xs uppercase text-stellar-muted">
      risk: {statusLabel(riskLevel)}
    </span>

    <span class={`border px-2 py-1 font-mono text-xs uppercase ${classForSafety(safetyStatus)}`}>
      asset safety: {statusLabel(safetyStatus)}
    </span>
  </div>

  <p class="mt-4 text-sm text-stellar-muted">
    {safetySummary ?? 'このアドオンの配布ファイルには、まだ公開表示できる安全性チェック結果がありません。'}
  </p>

  <p class="mt-3 font-mono text-xs text-stellar-muted">
    checked: {formatDate(safetyCheckedAt)}
  </p>

  <p class="mt-4 text-xs leading-6 text-stellar-muted">
    このチェックは静的検査です。Stellar本体の公式保守対象であることを意味しません。
  </p>
</section>
