---
import { t, type Lang } from '@/lib/i18n';
const { lang } = Astro.props as { lang: Lang };

const copy = {
  ja: {
    actions: ['Wikiを開く', 'アドオンを見る', '開発者ポータル', 'GitHub', 'ダウンロード'],
    arc: '読む。考える。書く。つなげる。',
    vol: 'VOL. 01 / 2026 / TRANSMISSION',
    est: 'EST. 2026',
    ok: 'TRANSMISSION 01 / OK',
    logTitle: '◯ 全システム静穏',
    logs: [
      '◯ NO PUSH · NO HURRY',
      '◯ LOCAL FIRST · USER OWNED'
    ]
  },
  en: {
    actions: ['Open Wiki', 'Browse Addons', 'Developer Portal', 'GitHub', 'Download'],
    arc: 'Read. Think. Write. Connect.',
    vol: 'VOL. 01 / 2026 / TRANSMISSION',
    est: 'EST. 2026',
    ok: 'TRANSMISSION 01 / OK',
    logTitle: '◯ ALL SYSTEMS QUIET',
    logs: [
      '◯ NO PUSH · NO HURRY',
      '◯ LOCAL FIRST · USER OWNED'
    ]
  },
  fr: {
    actions: ['Ouvrir le Wiki', 'Voir les extensions', 'Portail développeur', 'GitHub', 'Versions'],
    arc: 'Lire. Penser. Écrire. Relier.',
    vol: 'VOL. 01 / 2026 / TRANSMISSION',
    est: 'ÉTABLI 2026',
    ok: 'TRANSMISSION 01 / OK',
    logTitle: '◯ TOUS LES SYSTÈMES CALMES',
    logs: [
      '◯ PAS DE PRESSION · PAS DE HÂTE',
      '◯ LOCAL · PROPRIÉTÉ UTILISATEUR'
    ]
  },
  af: {
    actions: ['Maak Wiki oop', 'Blaai deur byvoegings', 'Ontwikkelaarsportaal', 'GitHub', 'Aflaaie'],
    arc: 'Lees. Dink. Skryf. Verbind.',
    vol: 'VOL. 01 / 2026 / TRANSMISSION',
    est: 'GESTIG 2026',
    ok: 'TRANSMISSION 01 / OK',
    logTitle: '◯ ALLE STELSELS STIL',
    logs: [
      '◯ GEEN DRUK · GEEN HAAS',
      '◯ PLAASLIK · GEBRUIKER BESIT'
    ]
  }
}[lang];
---
<section class="shiosai-hero relative min-h-[78vh] overflow-hidden border-b border-stellar-border">
  <div class="relative z-10 grid gap-8 px-4 py-16 sm:px-8 lg:grid-cols-[1fr_320px] lg:py-24">
    <div>
      <p class="inline-flex rounded-full bg-[var(--gold)] px-6 py-3 font-mono text-xs font-bold uppercase tracking-[.22em] text-stellar-text">
        <span class="mr-3 text-stellar-accent">●</span>{copy.vol}
      </p>
      <h1 class="mt-12 max-w-3xl font-mono text-5xl font-bold tracking-[.16em] text-stellar-accent2 sm:text-7xl">{t(lang, 'portal')}</h1>
      <p class="mt-6 max-w-2xl text-2xl font-bold leading-10 text-stellar-text">{t(lang, 'tagline')}</p>
      <p class="mt-6 font-mono text-lg font-bold tracking-[.12em] text-stellar-accent">{t(lang, 'readThinkWrite')}</p>
      <div class="mt-10 flex flex-wrap gap-3">
      <a class="btn btn-primary" href={`/${lang}/wiki`}>{copy.actions[0]}</a>
      <a class="btn" href={`/${lang}/addons`}>{copy.actions[1]}</a>
      <a class="btn" href={`/${lang}/developers`}>{copy.actions[2]}</a>
      <a class="btn" href="https://github.com/toutoutoubun/stellar">{copy.actions[3]}</a>
      <a class="btn" href="https://github.com/toutoutoubun/stellar/releases" target="_blank" rel="noreferrer">{copy.actions[4]}</a>
      </div>
    </div>
    <div class="font-mono text-xs font-bold uppercase leading-7 tracking-[.18em] text-stellar-accent2 lg:text-right">
      <p>{copy.est}</p>
      <p>{t(lang, 'coordinate')}</p>
      <p>{copy.ok}</p>
      <div class="mt-10 inline-grid gap-2 text-left text-stellar-accent2">
        <p>{copy.logTitle}</p>
        {copy.logs.map((line) => <p>{line}</p>)}
      </div>
    </div>
  </div>
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-[57%] top-[23%] h-[43rem] w-[43rem] rounded-full border-[6px] border-[var(--gold)] opacity-90"></div>
    <p class="arc-text">{copy.arc}</p>
    <p class="absolute bottom-[22%] left-[49%] text-8xl font-black leading-none text-[var(--pale-blue)]">≋</p>
    <span class="absolute left-[35%] top-[25%] h-16 w-64 rounded-[50%] border-2 border-dashed border-[var(--pale-blue)]"></span>
    <span class="absolute bottom-[13%] left-[8%] h-12 w-12 rounded-full bg-stellar-accent"></span>
    <span class="absolute right-[11%] top-[25%] h-24 w-24 rounded-full bg-[var(--gold)]"></span>
    <span class="absolute bottom-[9%] right-[12%] text-5xl text-stellar-accent">✦</span>
    <span class="absolute left-[8%] top-[53%] h-5 w-5 rounded-full bg-[#d98a76]"></span>
    <span class="absolute left-[43%] top-[50%] h-3 w-3 rounded-full bg-[#bf5b3a]"></span>
  </div>
</section>
