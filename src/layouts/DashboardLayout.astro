---
import BaseLayout from './BaseLayout.astro';
import { normalizeLang } from '@/lib/i18n';
const lang = normalizeLang(Astro.params.lang);
const { title = 'Dashboard' } = Astro.props;
const labels = {
  ja: {
    console: 'й–‹з™єиЂ…г‚ігѓіг‚Ѕгѓјгѓ«',
    dashboard: 'гѓЂгѓѓг‚·гѓҐгѓњгѓјгѓ‰',
    addons: 'г‚ўгѓ‰г‚Єгѓі',
    wikiEditor: 'Wikiз·Ёй›†',
    developerProfile: 'й–‹з™єиЂ…гѓ—гѓ­гѓ•г‚Јгѓјгѓ«',
    subscription: 'еҐ‘зґ„',
    account: 'г‚ўг‚«г‚¦гѓігѓ€'
  },
  en: {
    console: 'developer console',
    dashboard: 'dashboard',
    addons: 'addons',
    wikiEditor: 'wiki editor',
    developerProfile: 'developer profile',
    subscription: 'subscription',
    account: 'account'
  },
  fr: {
    console: 'console dГ©veloppeur',
    dashboard: 'tableau de bord',
    addons: 'extensions',
    wikiEditor: 'Г©dition du Wiki',
    developerProfile: 'profil dГ©veloppeur',
    subscription: 'abonnement',
    account: 'compte'
  },
  af: {
    console: 'ontwikkelaarskonsole',
    dashboard: 'paneel',
    addons: 'byvoegings',
    wikiEditor: 'wiki-redigeerder',
    developerProfile: 'ontwikkelaarsprofiel',
    subscription: 'intekening',
    account: 'rekening'
  }
}[lang];
const items = [
  [labels.dashboard, `/${lang}/dashboard`],
  [labels.addons, `/${lang}/dashboard/addons`],
  [labels.wikiEditor, `/${lang}/dashboard/wiki`],
  [labels.developerProfile, `/${lang}/dashboard/profile`],
  [labels.subscription, `/${lang}/dashboard/subscription`],
  [labels.account, `/${lang}/account`]
];
---
<BaseLayout title={title} lang={lang}>
  <div class="grid gap-6 lg:grid-cols-[240px_1fr]">
    <aside class="terminal-panel h-fit p-4 font-mono text-sm">
      <p class="mb-4 text-xs uppercase tracking-[.22em] text-stellar-muted">{labels.console}</p>
      <nav class="grid gap-2">
        {items.map(([label, href]) => <a class="border border-stellar-border px-3 py-2 hover:border-stellar-accent" href={href}>{label}</a>)}
      </nav>
    </aside>
    <section>
      <slot />
    </section>
  </div>
</BaseLayout>
