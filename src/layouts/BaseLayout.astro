---
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { alternateLinks, absoluteUrl } from '@/lib/seo';
import { getEnv } from '@/lib/env';
import { normalizeLang, type Lang } from '@/lib/i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  image?: string;
}

const env = getEnv();
const lang = Astro.props.lang ?? normalizeLang(Astro.params.lang);
const title = Astro.props.title ? `${Astro.props.title} / Stellar Portal` : 'Stellar Portal';
const defaultDescriptions: Record<Lang, string> = {
  ja: 'Stellarの公式ポータル。Wiki、アドオン、開発者登録、審査済みコミュニティ拡張を扱います。',
  en: 'A local-first research portal for Stellar: Wiki, addons, developer registration, and reviewed community extensions.',
  fr: 'Portail officiel de Stellar : Wiki, extensions, inscription développeur et extensions communautaires examinées.',
  af: 'Stellar se amptelike portaal vir Wiki, byvoegings, ontwikkelaarregistrasie en gekeurde gemeenskapsuitbreidings.'
};
const description = Astro.props.description ?? defaultDescriptions[lang];
const canonical = absoluteUrl(Astro.url.pathname, env.PUBLIC_SITE_URL);
const image = absoluteUrl(Astro.props.image ?? '/og-default.svg', env.PUBLIC_SITE_URL);
const alts = alternateLinks(Astro.url.pathname, env.PUBLIC_SITE_URL);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alts.map((alt) => <link rel="alternate" hreflang={alt.lang} href={alt.href} />)}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Header lang={lang} />
    <main class="mx-auto min-h-[70vh] w-full px-4 py-10 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
